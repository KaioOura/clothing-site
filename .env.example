# ─── MERCADO PAGO ───────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-000000000

# ─── BANCO DE DADOS (Railway preenche automaticamente) ──────
DATABASE_URL=postgresql://usuario:senha@host:5432/maison_br

# ─── SERVIDOR ───────────────────────────────────────────────
PORT=3001

# ─── URL DO FRONTEND (onde está hospedado o index.html) ─────
# Em desenvolvimento use: http://localhost:3000
# Em produção use a URL real do seu site
FRONTEND_URL=http://localhost:3000

# ─── URL DO BACKEND (usada para o webhook do Mercado Pago) ──
# Em desenvolvimento use ngrok (explicado nas instruções)
# Em produção use a URL do Railway: https://seu-app.railway.app
BACKEND_URL=https://seu-app.railway.app

# ─── SEGURANÇA ──────────────────────────────────────────────
# Qualquer string aleatória longa — usada para validar webhooks
WEBHOOK_SECRET=troque_por_string_aleatoria_longa_aqui
